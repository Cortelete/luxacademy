    "start": "node dist/server.cjs"
  },
  "dependencies": {
    "@google/genai": "^2.6.0",
    "@vercel/analytics": "^1.3.1",
    "@vercel/node": "^5.8.4",
    "express": "^5.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.11.24",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.20.2",
    "tsx": "^4.22.3",
    "typescript": "^5.3.3",
    "vite": "^8.0.14"
  }
}
